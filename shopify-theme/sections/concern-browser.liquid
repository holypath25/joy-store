{% liquid
  assign skin_title    = section.settings.skin_title    | default: '피부 고민별 제품'
  assign health_title  = section.settings.health_title  | default: '건강 증상별 제품'
  assign section_title = section.settings.section_title | default: '어떤 고민이 있으신가요?'
  assign section_sub   = section.settings.section_sub   | default: '고민을 선택하면 맞춤 제품을 바로 확인할 수 있어요.'
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} concern-browser-section" style="{% render 'spacing-style', settings: section.settings %}">

  {% if section_title != blank %}
    <div class="concern-browser__header">
      <h2 class="concern-browser__title">{{ section_title }}</h2>
      {% if section_sub != blank %}
        <p class="concern-browser__sub">{{ section_sub }}</p>
      {% endif %}
    </div>
  {% endif %}

  <!-- 탭 버튼 -->
  <div class="concern-browser__tabs" role="tablist">
    <button
      class="concern-browser__tab concern-browser__tab--active"
      role="tab"
      aria-selected="true"
      aria-controls="panel-skin"
      data-tab="skin"
    >
      ✨ {{ skin_title }}
    </button>
    <button
      class="concern-browser__tab"
      role="tab"
      aria-selected="false"
      aria-controls="panel-health"
      data-tab="health"
    >
      💊 {{ health_title }}
    </button>
  </div>

  <!-- 피부 고민 패널 -->
  <div id="panel-skin" class="concern-browser__panel concern-browser__panel--active" role="tabpanel">
    <div class="concern-browser__grid">

      {%- assign skin_concerns = '색소침착·기미,여드름,상처·흉터,주름,피부 탄력,건조·수분,모공,민감성 피부,다크서클,피부 재생' | split: ',' -%}
      {%- assign skin_emojis   = '🌑,😣,🩹,〰️,💪,💧,🔍,🌸,👁️,🌱' | split: ',' -%}
      {%- assign skin_handles  = 'skin-pigmentation,acne,wounds-scars,wrinkles,skin-elasticity,skin-dryness,pores,sensitive-skin,dark-circles,skin-regeneration' | split: ',' -%}
      {%- assign skin_descs    = '기미·잡티·색소 개선,트러블·여드름성 피부,흉터 완화·상처 케어,잔주름·깊은 주름 개선,탄력 저하·처짐 개선,수분 공급·건조 피부,모공 관리·피지 케어,자극·민감성 피부 진정,눈가 다크서클 개선,피부 재생·회복 촉진' | split: ',' -%}

      {% for concern in skin_concerns %}
        {%- assign idx    = forloop.index0 -%}
        {%- assign emoji  = skin_emojis[idx] -%}
        {%- assign handle = skin_handles[idx] -%}
        {%- assign desc   = skin_descs[idx] -%}
        {%- assign col    = collections[handle] -%}
        {%- assign url    = '/collections/' | append: handle -%}
        {%- if col.handle == handle -%}
          {%- assign url = col.url -%}
        {%- endif -%}

        <a href="{{ url }}" class="concern-card concern-card--skin">
          <span class="concern-card__emoji">{{ emoji }}</span>
          <span class="concern-card__name">{{ concern }}</span>
          <span class="concern-card__desc">{{ desc }}</span>
          {%- if col.handle == handle and col.products_count > 0 -%}
            <span class="concern-card__count">{{ col.products_count }}개 제품</span>
          {%- endif -%}
          <span class="concern-card__arrow">→</span>
        </a>
      {% endfor %}

    </div>
  </div>

  <!-- 건강 증상 패널 -->
  <div id="panel-health" class="concern-browser__panel" role="tabpanel">
    <div class="concern-browser__grid">

      {%- assign health_concerns = '감기,발열·열,기침,콧물·코막힘,두통,소화불량,피로·무기력,관절·근육통,알레르기,수면장애' | split: ',' -%}
      {%- assign health_emojis   = '🤧,🌡️,😮‍💨,👃,🤕,🫃,😴,🦴,🌿,😴' | split: ',' -%}
      {%- assign health_handles  = 'cold,fever,cough,runny-nose,headache,indigestion,fatigue,joint-pain,allergy,sleep' | split: ',' -%}
      {%- assign health_descs    = '감기 초기·면역 강화,열 완화·해열,기침·목 통증 완화,코막힘·비염 케어,두통·편두통 완화,소화·위장 관리,피로 회복·에너지,관절·근육 통증 완화,알레르기·비염 관리,수면 개선·불면증' | split: ',' -%}

      {% for concern in health_concerns %}
        {%- assign idx    = forloop.index0 -%}
        {%- assign emoji  = health_emojis[idx] -%}
        {%- assign handle = health_handles[idx] -%}
        {%- assign desc   = health_descs[idx] -%}
        {%- assign col    = collections[handle] -%}
        {%- assign url    = '/collections/' | append: handle -%}
        {%- if col.handle == handle -%}
          {%- assign url = col.url -%}
        {%- endif -%}

        <a href="{{ url }}" class="concern-card concern-card--health">
          <span class="concern-card__emoji">{{ emoji }}</span>
          <span class="concern-card__name">{{ concern }}</span>
          <span class="concern-card__desc">{{ desc }}</span>
          {%- if col.handle == handle and col.products_count > 0 -%}
            <span class="concern-card__count">{{ col.products_count }}개 제품</span>
          {%- endif -%}
          <span class="concern-card__arrow">→</span>
        </a>
      {% endfor %}

    </div>
  </div>

</div>

{% stylesheet %}
  .concern-browser-section {
    padding-inline: var(--page-margin, 1.5rem);
  }

  .concern-browser__header {
    text-align: center;
    margin-block-end: 2rem;
  }

  .concern-browser__title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  .concern-browser__sub {
    color: var(--color-foreground-muted, #666);
    font-size: 0.95rem;
    margin: 0;
  }

  .concern-browser__tabs {
    display: flex;
    gap: 0.5rem;
    margin-block-end: 1.5rem;
    border-bottom: 2px solid var(--color-border, #e5e7eb);
    padding-block-end: 0;
  }

  .concern-browser__tab {
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    padding: 0.75rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    color: var(--color-foreground-muted, #888);
    transition: color 0.2s, border-color 0.2s;
    border-radius: 0;
    font-family: inherit;
  }

  .concern-browser__tab--active,
  .concern-browser__tab:hover {
    color: var(--color-foreground, #111);
    border-bottom-color: var(--color-foreground, #111);
  }

  .concern-browser__panel {
    display: none;
  }

  .concern-browser__panel--active {
    display: block;
  }

  .concern-browser__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media screen and (min-width: 480px) {
    .concern-browser__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (min-width: 750px) {
    .concern-browser__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .concern-browser__grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .concern-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.25rem 0.75rem;
    border-radius: 1rem;
    border: 1.5px solid var(--color-border, #e5e7eb);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
    gap: 0.3rem;
    position: relative;
  }

  .concern-card:hover {
    border-color: var(--color-foreground, #111);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .concern-card__emoji {
    font-size: 2rem;
    line-height: 1;
    margin-block-end: 0.25rem;
  }

  .concern-card__name {
    font-weight: 700;
    font-size: 0.9rem;
    line-height: 1.2;
  }

  .concern-card__desc {
    font-size: 0.72rem;
    color: var(--color-foreground-muted, #888);
    line-height: 1.3;
  }

  .concern-card__count {
    font-size: 0.7rem;
    font-weight: 600;
    background: var(--color-foreground, #111);
    color: var(--color-background, #fff);
    padding: 0.15rem 0.5rem;
    border-radius: 20px;
    margin-top: 0.2rem;
  }

  .concern-card__arrow {
    position: absolute;
    top: 0.6rem;
    right: 0.75rem;
    font-size: 0.75rem;
    color: var(--color-foreground-muted, #aaa);
    transition: color 0.2s;
  }

  .concern-card:hover .concern-card__arrow {
    color: var(--color-foreground, #111);
  }
{% endstylesheet %}

<script>
  (function() {
    var tabs = document.querySelectorAll('[data-tab]');
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        var target = this.dataset.tab;
        tabs.forEach(function(t) {
          t.classList.remove('concern-browser__tab--active');
          t.setAttribute('aria-selected', 'false');
        });
        this.classList.add('concern-browser__tab--active');
        this.setAttribute('aria-selected', 'true');

        document.querySelectorAll('.concern-browser__panel').forEach(function(p) {
          p.classList.remove('concern-browser__panel--active');
        });
        var panel = document.getElementById('panel-' + target);
        if (panel) panel.classList.add('concern-browser__panel--active');
      });
    });
  })();
</script>

{% schema %}
{
  "name": "고민별 컬렉션",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "섹션 제목",
      "default": "어떤 고민이 있으신가요?"
    },
    {
      "type": "text",
      "id": "section_sub",
      "label": "섹션 설명",
      "default": "고민을 선택하면 맞춤 제품을 바로 확인할 수 있어요."
    },
    {
      "type": "text",
      "id": "skin_title",
      "label": "피부 고민 탭 이름",
      "default": "피부 고민별 제품"
    },
    {
      "type": "text",
      "id": "health_title",
      "label": "건강 증상 탭 이름",
      "default": "건강 증상별 제품"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "색상 테마",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "섹션 너비",
      "options": [
        { "value": "page-width", "label": "페이지 너비" },
        { "value": "full-width", "label": "전체 너비" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "여백"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "상단 여백",
      "min": 0, "max": 100, "step": 4, "unit": "px", "default": 60
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "하단 여백",
      "min": 0, "max": 100, "step": 4, "unit": "px", "default": 60
    }
  ],
  "presets": [
    {
      "name": "고민별 컬렉션",
      "category": "컬렉션"
    }
  ]
}
{% endschema %}
